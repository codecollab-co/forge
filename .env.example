# Local development environment variables.
# Copy to .env before `docker compose up`.
# These are TEST keys committed for convenience — never use in production.

# RS256 JWT keypair (PEM-encoded, single line with literal \n for newlines).
# Generate a fresh pair locally with:
#   openssl genpkey -algorithm RSA -out jwt.key -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in jwt.key -pubout -out jwt.pub
# Then paste the contents (newlines escaped as \n) into the variables below.

JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"
