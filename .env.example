# Local development environment variables.
# Copy to .env before `docker compose up`.
# These are TEST keys committed for convenience — never use in production.

# RS256 JWT keypair (PEM-encoded, single line with literal \n for newlines).
# Generate a fresh pair locally with:
#   openssl genpkey -algorithm RSA -out jwt.key -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in jwt.key -pubout -out jwt.pub
# Then paste the contents (newlines escaped as \n) into the variables below.

JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"

# OAuth provider credentials. Create OAuth apps at:
#   GitHub: https://github.com/settings/developers
#     Authorization callback URL: http://localhost:8080/auth/callback/github
#   Google: https://console.cloud.google.com/apis/credentials
#     Authorized redirect URI:    http://localhost:8080/auth/callback/google

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# E2B sandbox provider (slice 7+). Leave empty to use the in-memory fake
# sandbox locally. Set to a real key to switch to E2B (lands with slice 8).
E2B_API_KEY=

# Anthropic API key for the Author Agent (slice 8). Required if you want
# to actually run the agent loop end-to-end against the API.
ANTHROPIC_API_KEY=
